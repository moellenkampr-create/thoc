<form class="urop-sheet" autocomplete="off">
  <header class="sheet-header">
    <img class="profile-img" src="{{actor.img}}" data-edit="img" title="{{actor.name}}" height="96" width="96"/>
    <div class="header-main">
      <input name="name" type="text" value="{{actor.name}}" placeholder="{{localize 'URoP.Character.Name'}}"/>
      <div class="quick-rolls">
        <button type="button" data-action="roll-urop" data-label="{{localize 'URoP.Roll.Generic'}}">{{localize "URoP.Roll.ButtonUrop"}}</button>
        <button type="button" data-action="roll-initiative">{{localize "URoP.Roll.InitiativeComparison"}}</button>
      </div>
    </div>
  </header>

  <nav class="sheet-tabs tabs" data-group="primary">
    <a class="item" data-tab="overview">{{localize "URoP.Tab.Overview"}}</a>
    <a class="item" data-tab="attributes">{{localize "URoP.Tab.Attributes"}}</a>
    <a class="item" data-tab="skills">{{localize "URoP.Tab.Skills"}}</a>
    <a class="item" data-tab="combat">{{localize "URoP.Tab.Combat"}}</a>
    <a class="item" data-tab="items">{{localize "URoP.Tab.Items"}}</a>
    <a class="item" data-tab="maneuvers">{{localize "URoP.Tab.Maneuvers"}}</a>
    <a class="item" data-tab="advanced">{{localize "URoP.Tab.Advanced"}}</a>
  </nav>

  <section class="sheet-body">
    <div class="tab" data-group="primary" data-tab="overview">
      <div class="grid two-col">
        <div class="card">
          <h3>{{localize "URoP.Section.Resources"}}</h3>
          <label>{{localize "URoP.Field.EPTotal"}}</label>
          <input type="number" name="system.resources.epTotal" value="{{actor.system.resources.epTotal}}"/>
          <div class="field-header">
            <label>{{localize "URoP.Field.EPSpent"}}</label>
            <span class="hover-help help-icon" data-help="{{localize 'URoP.Help.EPSpentRecalc'}}">?</span>
          </div>
          <input type="number" name="system.resources.epSpent" value="{{actor.system.resources.epSpent}}"/>
          <button type="button" data-action="recalc-ep" class="secondary-action">{{localize "URoP.Field.RecalculateEP"}}</button>
        </div>

        <div class="card">
          <h3>{{localize "URoP.Section.OverviewNotes"}}</h3>
          <label>{{localize "URoP.Field.Appearance"}}</label>
          <textarea name="system.notes.summary">{{actor.system.notes.summary}}</textarea>
          <label>{{localize "URoP.Field.Backstory"}}</label>
          <textarea class="large" name="system.notes.backstory">{{actor.system.notes.backstory}}</textarea>
        </div>
      </div>
    </div>

    <div class="tab" data-group="primary" data-tab="attributes">
      <div class="card focus-card">
        <div class="field-header">
          <label>{{localize "URoP.Field.FocusAttributes"}}</label>
          <span class="hover-help help-icon" data-help="{{localize 'URoP.Help.FocusAttributes'}}">?</span>
        </div>
        <div class="focus-row">
          <label><input type="checkbox" data-action="toggle-focus-attribute" data-attribute="koerper" {{#if isKoerperFocus}}checked{{/if}}/> Körper</label>
          <label><input type="checkbox" data-action="toggle-focus-attribute" data-attribute="geist" {{#if isGeistFocus}}checked{{/if}}/> Geist</label>
          <label><input type="checkbox" data-action="toggle-focus-attribute" data-attribute="praesenz" {{#if isPraesenzFocus}}checked{{/if}}/> Präsenz</label>
          <button type="button" class="lock-btn" data-action="toggle-focus-lock" title="{{localize 'URoP.Field.FocusLock'}}">{{#if isFocusSelectionLocked}}🔒{{else}}🔓{{/if}}</button>
        </div>
      </div>
      <div class="grid three-col">

        {{!-- KÖRPER --}}
        <div class="card attr-card">
          <div class="attr-header">
            <span class="attr-label hover-help" data-help="{{localize 'URoP.Attr.KoerperHelp'}}">Körper</span>
            <div class="attr-stepper">
              <button type="button" class="stepper-btn" data-action="attr-decrement" data-path="system.attributes.staerke">−</button>
              <input type="number" class="attr-value" name="system.attributes.staerke" value="{{actor.system.attributes.staerke}}" data-locked="true" readonly/>
              <button type="button" class="stepper-btn" data-action="attr-increment" data-path="system.attributes.staerke">+</button>
            </div>
            <button type="button" class="lock-btn" data-action="toggle-lock" data-target="system.attributes.staerke" title="Bearbeiten sperren/entsperren">🔒</button>
          </div>
          <hr class="attr-divider"/>
          <div class="facet-head">
            <span></span>
            <span class="facet-col-head facet-col-delta hover-help" data-help="{{localize 'URoP.Help.FacetDelta'}}">{{localize "URoP.Field.FacetDelta"}}</span>
            <span class="facet-col-head">{{localize "URoP.Field.FacetTotal"}}</span>
            <span></span>
          </div>
          <div class="facet-row">
            <span class="facet-label hover-help" data-help="{{localize 'URoP.Facet.StaerkeHelp'}}">Stärke</span>
            <div class="facet-stepper">
              <button type="button" class="stepper-btn" data-action="facet-decrement" data-path="system.attributes.staerke">−</button>
              <input type="number" class="facet-value" name="system.attributes.staerke" value="{{actor.system.attributes.staerke}}" data-locked="true" readonly/>
              <button type="button" class="stepper-btn" data-action="facet-increment" data-path="system.attributes.staerke">+</button>
            </div>
            <span class="facet-total">{{leadAttributeDerived.koerper}}</span>
            <button type="button" class="lock-btn" data-action="toggle-lock" data-target="system.attributes.staerke" title="Bearbeiten sperren/entsperren">🔒</button>
          </div>
          <div class="facet-row">
            <span class="facet-label hover-help" data-help="{{localize 'URoP.Facet.GrobmotorikHelp'}}">Grobmotorik</span>
            <div class="facet-stepper">
              <button type="button" class="stepper-btn" data-action="facet-decrement" data-path="system.attributes.grobmotorik">−</button>
              <input type="number" class="facet-value" name="system.attributes.grobmotorik" value="{{actor.system.attributes.grobmotorik}}" data-locked="true" readonly/>
              <button type="button" class="stepper-btn" data-action="facet-increment" data-path="system.attributes.grobmotorik">+</button>
            </div>
            <span class="facet-total">{{leadAttributeDerived.koerper}}</span>
            <button type="button" class="lock-btn" data-action="toggle-lock" data-target="system.attributes.grobmotorik" title="Bearbeiten sperren/entsperren">🔒</button>
          </div>
          <div class="facet-row">
            <span class="facet-label hover-help" data-help="{{localize 'URoP.Facet.FeinmotorikHelp'}}">Feinmotorik</span>
            <div class="facet-stepper">
              <button type="button" class="stepper-btn" data-action="facet-decrement" data-path="system.attributes.feinmotorik">−</button>
              <input type="number" class="facet-value" name="system.attributes.feinmotorik" value="{{actor.system.attributes.feinmotorik}}" data-locked="true" readonly/>
              <button type="button" class="stepper-btn" data-action="facet-increment" data-path="system.attributes.feinmotorik">+</button>
            </div>
            <span class="facet-total">{{leadAttributeDerived.koerper}}</span>
            <button type="button" class="lock-btn" data-action="toggle-lock" data-target="system.attributes.feinmotorik" title="Bearbeiten sperren/entsperren">🔒</button>
          </div>
          <div class="facet-row">
            <span class="facet-label hover-help" data-help="{{localize 'URoP.Facet.KonstitutionHelp'}}">Konstitution</span>
            <div class="facet-stepper">
              <button type="button" class="stepper-btn" data-action="facet-decrement" data-path="system.attributes.konstitution">−</button>
              <input type="number" class="facet-value" name="system.attributes.konstitution" value="{{actor.system.attributes.konstitution}}" data-locked="true" readonly/>
              <button type="button" class="stepper-btn" data-action="facet-increment" data-path="system.attributes.konstitution">+</button>
            </div>
            <span class="facet-total">{{leadAttributeDerived.koerper}}</span>
            <button type="button" class="lock-btn" data-action="toggle-lock" data-target="system.attributes.konstitution" title="Bearbeiten sperren/entsperren">🔒</button>
          </div>
        </div>

        {{!-- GEIST --}}
        <div class="card attr-card">
          <div class="attr-header">
            <span class="attr-label hover-help" data-help="{{localize 'URoP.Attr.GeistHelp'}}">Geist</span>
            <div class="attr-stepper">
              <button type="button" class="stepper-btn" data-action="attr-decrement" data-path="system.attributes.analyse">−</button>
              <input type="number" class="attr-value" name="system.attributes.analyse" value="{{actor.system.attributes.analyse}}" data-locked="true" readonly/>
              <button type="button" class="stepper-btn" data-action="attr-increment" data-path="system.attributes.analyse">+</button>
            </div>
            <button type="button" class="lock-btn" data-action="toggle-lock" data-target="system.attributes.analyse" title="Bearbeiten sperren/entsperren">🔒</button>
          </div>
          <hr class="attr-divider"/>
          <div class="facet-head">
            <span></span>
            <span class="facet-col-head facet-col-delta hover-help" data-help="{{localize 'URoP.Help.FacetDelta'}}">{{localize "URoP.Field.FacetDelta"}}</span>
            <span class="facet-col-head">{{localize "URoP.Field.FacetTotal"}}</span>
            <span></span>
          </div>
          <div class="facet-row">
            <span class="facet-label hover-help" data-help="{{localize 'URoP.Facet.AnalyseHelp'}}">Analyse</span>
            <div class="facet-stepper">
              <button type="button" class="stepper-btn" data-action="facet-decrement" data-path="system.attributes.analyse">−</button>
              <input type="number" class="facet-value" name="system.attributes.analyse" value="{{actor.system.attributes.analyse}}" data-locked="true" readonly/>
              <button type="button" class="stepper-btn" data-action="facet-increment" data-path="system.attributes.analyse">+</button>
            </div>
            <span class="facet-total">{{leadAttributeDerived.geist}}</span>
            <button type="button" class="lock-btn" data-action="toggle-lock" data-target="system.attributes.analyse" title="Bearbeiten sperren/entsperren">🔒</button>
          </div>
          <div class="facet-row">
            <span class="facet-label hover-help" data-help="{{localize 'URoP.Facet.WillenskraftHelp'}}">Willenskraft</span>
            <div class="facet-stepper">
              <button type="button" class="stepper-btn" data-action="facet-decrement" data-path="system.attributes.willenskraft">−</button>
              <input type="number" class="facet-value" name="system.attributes.willenskraft" value="{{actor.system.attributes.willenskraft}}" data-locked="true" readonly/>
              <button type="button" class="stepper-btn" data-action="facet-increment" data-path="system.attributes.willenskraft">+</button>
            </div>
            <span class="facet-total">{{leadAttributeDerived.geist}}</span>
            <button type="button" class="lock-btn" data-action="toggle-lock" data-target="system.attributes.willenskraft" title="Bearbeiten sperren/entsperren">🔒</button>
          </div>
          <div class="facet-row">
            <span class="facet-label hover-help" data-help="{{localize 'URoP.Facet.AufmerksamkeitHelp'}}">Aufmerksamkeit</span>
            <div class="facet-stepper">
              <button type="button" class="stepper-btn" data-action="facet-decrement" data-path="system.attributes.aufmerksamkeit">−</button>
              <input type="number" class="facet-value" name="system.attributes.aufmerksamkeit" value="{{actor.system.attributes.aufmerksamkeit}}" data-locked="true" readonly/>
              <button type="button" class="stepper-btn" data-action="facet-increment" data-path="system.attributes.aufmerksamkeit">+</button>
            </div>
            <span class="facet-total">{{leadAttributeDerived.geist}}</span>
            <button type="button" class="lock-btn" data-action="toggle-lock" data-target="system.attributes.aufmerksamkeit" title="Bearbeiten sperren/entsperren">🔒</button>
          </div>
          <div class="facet-row">
            <span class="facet-label hover-help" data-help="{{localize 'URoP.Facet.IntuitionHelp'}}">Intuition</span>
            <div class="facet-stepper">
              <button type="button" class="stepper-btn" data-action="facet-decrement" data-path="system.attributes.intuition">−</button>
              <input type="number" class="facet-value" name="system.attributes.intuition" value="{{actor.system.attributes.intuition}}" data-locked="true" readonly/>
              <button type="button" class="stepper-btn" data-action="facet-increment" data-path="system.attributes.intuition">+</button>
            </div>
            <span class="facet-total">{{leadAttributeDerived.geist}}</span>
            <button type="button" class="lock-btn" data-action="toggle-lock" data-target="system.attributes.intuition" title="Bearbeiten sperren/entsperren">🔒</button>
          </div>
        </div>

        {{!-- PRÄSENZ --}}
        <div class="card attr-card">
          <div class="attr-header">
            <span class="attr-label hover-help" data-help="{{localize 'URoP.Attr.PraesenzHelp'}}">Präsenz</span>
            <div class="attr-stepper">
              <button type="button" class="stepper-btn" data-action="attr-decrement" data-path="system.attributes.ausdruck">−</button>
              <input type="number" class="attr-value" name="system.attributes.ausdruck" value="{{actor.system.attributes.ausdruck}}" data-locked="true" readonly/>
              <button type="button" class="stepper-btn" data-action="attr-increment" data-path="system.attributes.ausdruck">+</button>
            </div>
            <button type="button" class="lock-btn" data-action="toggle-lock" data-target="system.attributes.ausdruck" title="Bearbeiten sperren/entsperren">🔒</button>
          </div>
          <hr class="attr-divider"/>
          <div class="facet-head">
            <span></span>
            <span class="facet-col-head facet-col-delta hover-help" data-help="{{localize 'URoP.Help.FacetDelta'}}">{{localize "URoP.Field.FacetDelta"}}</span>
            <span class="facet-col-head">{{localize "URoP.Field.FacetTotal"}}</span>
            <span></span>
          </div>
          <div class="facet-row">
            <span class="facet-label hover-help" data-help="{{localize 'URoP.Facet.AusdruckHelp'}}">Ausdruck</span>
            <div class="facet-stepper">
              <button type="button" class="stepper-btn" data-action="facet-decrement" data-path="system.attributes.ausdruck">−</button>
              <input type="number" class="facet-value" name="system.attributes.ausdruck" value="{{actor.system.attributes.ausdruck}}" data-locked="true" readonly/>
              <button type="button" class="stepper-btn" data-action="facet-increment" data-path="system.attributes.ausdruck">+</button>
            </div>
            <span class="facet-total">{{leadAttributeDerived.praesenz}}</span>
            <button type="button" class="lock-btn" data-action="toggle-lock" data-target="system.attributes.ausdruck" title="Bearbeiten sperren/entsperren">🔒</button>
          </div>
          <div class="facet-row">
            <span class="facet-label hover-help" data-help="{{localize 'URoP.Facet.EmpathieHelp'}}">Empathie</span>
            <div class="facet-stepper">
              <button type="button" class="stepper-btn" data-action="facet-decrement" data-path="system.attributes.empathie">−</button>
              <input type="number" class="facet-value" name="system.attributes.empathie" value="{{actor.system.attributes.empathie}}" data-locked="true" readonly/>
              <button type="button" class="stepper-btn" data-action="facet-increment" data-path="system.attributes.empathie">+</button>
            </div>
            <span class="facet-total">{{leadAttributeDerived.praesenz}}</span>
            <button type="button" class="lock-btn" data-action="toggle-lock" data-target="system.attributes.empathie" title="Bearbeiten sperren/entsperren">🔒</button>
          </div>
          <div class="facet-row">
            <span class="facet-label hover-help" data-help="{{localize 'URoP.Facet.DominanzHelp'}}">Dominanz</span>
            <div class="facet-stepper">
              <button type="button" class="stepper-btn" data-action="facet-decrement" data-path="system.attributes.dominanz">−</button>
              <input type="number" class="facet-value" name="system.attributes.dominanz" value="{{actor.system.attributes.dominanz}}" data-locked="true" readonly/>
              <button type="button" class="stepper-btn" data-action="facet-increment" data-path="system.attributes.dominanz">+</button>
            </div>
            <span class="facet-total">{{leadAttributeDerived.praesenz}}</span>
            <button type="button" class="lock-btn" data-action="toggle-lock" data-target="system.attributes.dominanz" title="Bearbeiten sperren/entsperren">🔒</button>
          </div>
          <div class="facet-row">
            <span class="facet-label hover-help" data-help="{{localize 'URoP.Facet.ResonanzHelp'}}">Resonanz</span>
            <div class="facet-stepper">
              <button type="button" class="stepper-btn" data-action="facet-decrement" data-path="system.attributes.resonanz">−</button>
              <input type="number" class="facet-value" name="system.attributes.resonanz" value="{{actor.system.attributes.resonanz}}" data-locked="true" readonly/>
              <button type="button" class="stepper-btn" data-action="facet-increment" data-path="system.attributes.resonanz">+</button>
            </div>
            <span class="facet-total">{{leadAttributeDerived.praesenz}}</span>
            <button type="button" class="lock-btn" data-action="toggle-lock" data-target="system.attributes.resonanz" title="Bearbeiten sperren/entsperren">🔒</button>
          </div>
        </div>

      </div>
    </div>

    <div class="tab" data-group="primary" data-tab="skills">
      <div class="card">
        <div class="list-header">
          <h3>Fertigkeiten</h3>
        </div>
        <ul class="item-list interactive-list">
          {{#each itemGroups.skill as |item|}}
          <li>
            <button type="button" class="item-open" data-action="open-item" data-item-id="{{item._id}}" title="{{#if item.system.rulesShort}}{{item.system.rulesShort}}{{else}}{{item.system.description}}{{/if}}">{{item.name}}</button>
            <span class="item-meta">{{item.system.ruleAnchors.[0]}} | {{item.system.ruleAnchors.[1]}} | {{item.system.ruleAnchors.[2]}} | Stufe {{item.system.level}}</span>
          </li>
          {{/each}}
        </ul>
      </div>
    </div>

    <div class="tab" data-group="primary" data-tab="combat">
      <div class="grid two-col">
        <div class="card">
          <h3>{{localize "URoP.Tab.Combat"}}</h3>
          <label>{{localize "URoP.Field.SizeClass"}}</label>
          <select name="system.sizeClass">
            <option value="G0" {{#if (uropEq actor.system.sizeClass "G0")}}selected{{/if}}>G0</option>
            <option value="G1" {{#if (uropEq actor.system.sizeClass "G1")}}selected{{/if}}>G1</option>
            <option value="G2" {{#if (uropEq actor.system.sizeClass "G2")}}selected{{/if}}>G2</option>
            <option value="G3" {{#if (uropEq actor.system.sizeClass "G3")}}selected{{/if}}>G3</option>
            <option value="G4" {{#if (uropEq actor.system.sizeClass "G4")}}selected{{/if}}>G4</option>
            <option value="G5" {{#if (uropEq actor.system.sizeClass "G5")}}selected{{/if}}>G5</option>
            <option value="G6" {{#if (uropEq actor.system.sizeClass "G6")}}selected{{/if}}>G6</option>
            <option value="G7" {{#if (uropEq actor.system.sizeClass "G7")}}selected{{/if}}>G7</option>
            <option value="G8" {{#if (uropEq actor.system.sizeClass "G8")}}selected{{/if}}>G8</option>
            <option value="G9" {{#if (uropEq actor.system.sizeClass "G9")}}selected{{/if}}>G9</option>
          </select>
          <label>{{localize "URoP.Field.PressureState"}}</label>
          <select name="system.pressure.state">
            <option value="none" {{#if (uropEq actor.system.pressure.state "none")}}selected{{/if}}>Kein Druck</option>
            <option value="reduced" {{#if (uropEq actor.system.pressure.state "reduced")}}selected{{/if}}>Reduzierter Druck</option>
            <option value="pressure" {{#if (uropEq actor.system.pressure.state "pressure")}}selected{{/if}}>Druck</option>
          </select>
          <label>{{localize "URoP.Field.Boosts"}}</label>
          <textarea name="system.combat.boostNotes">{{actor.system.combat.boostNotes}}</textarea>
        </div>

        <div class="card">
          <h3>Kampfuebersicht</h3>
          <label>Kampffertigkeiten</label>
          <ul class="item-list interactive-list">
            {{#each combatSkills as |item|}}
            <li>
              <button type="button" class="item-open" data-action="open-item" data-item-id="{{item._id}}">{{item.name}}</button>
              <span class="item-meta">Stufe {{item.system.level}}</span>
            </li>
            {{/each}}
          </ul>

          <label>Waffen</label>
          <ul class="item-list interactive-list">
            {{#each itemGroups.weapon as |item|}}
            <li>
              <button type="button" class="item-open" data-action="open-item" data-item-id="{{item._id}}">{{item.name}}</button>
              <span class="item-meta">{{item.system.designedForSizeClass}} → {{item.system.effectiveAgainstClass}} | N {{item.system.rangeBands.nah}} / M {{item.system.rangeBands.mittel}} / W {{item.system.rangeBands.weit}} / E {{item.system.rangeBands.extrem}}</span>
            </li>
            {{/each}}
          </ul>

          <label>Ruestung</label>
          <ul class="item-list interactive-list">
            {{#each itemGroups.armor as |item|}}
            <li>
              <button type="button" class="item-open" data-action="open-item" data-item-id="{{item._id}}">{{item.name}}</button>
              <span class="item-meta">{{item.system.userSizeNominal}} | Schutz {{item.system.protectionValue}}</span>
            </li>
            {{/each}}
          </ul>
        </div>
      </div>

      <div class="grid three-col">
        <div class="card">
          <h3>Leichte Konsequenzen</h3>
          <input type="text" name="system.consequences.light.0" value="{{actor.system.consequences.light.[0]}}"/>
          <input type="text" name="system.consequences.light.1" value="{{actor.system.consequences.light.[1]}}"/>
          <input type="text" name="system.consequences.light.2" value="{{actor.system.consequences.light.[2]}}"/>
        </div>
        <div class="card">
          <h3>Schwere Konsequenzen</h3>
          <input type="text" name="system.consequences.heavy.0" value="{{actor.system.consequences.heavy.[0]}}"/>
          <input type="text" name="system.consequences.heavy.1" value="{{actor.system.consequences.heavy.[1]}}"/>
        </div>
        <div class="card">
          <h3>Kritische Konsequenz</h3>
          <input type="text" name="system.consequences.critical.0" value="{{actor.system.consequences.critical.[0]}}"/>
        </div>
      </div>
    </div>

    <div class="tab" data-group="primary" data-tab="items">
      <div class="grid two-col">
        <div class="card">
          <div class="list-header">
            <h3>Ausrüstung</h3>
          </div>
          <ul class="item-list interactive-list">
            {{#each itemGroups.gear as |item|}}
            <li><button type="button" class="item-open" data-action="open-item" data-item-id="{{item._id}}" title="{{#if item.system.rulesShort}}{{item.system.rulesShort}}{{else}}{{item.system.description}}{{/if}}">{{item.name}}</button></li>
            {{/each}}
          </ul>

          <div class="list-header">
            <h3>Verbrauchsgegenstände</h3>
          </div>
          <ul class="item-list interactive-list">
            {{#each itemGroups.consumable as |item|}}
            <li><button type="button" class="item-open" data-action="open-item" data-item-id="{{item._id}}" title="{{#if item.system.rulesShort}}{{item.system.rulesShort}}{{else}}{{item.system.description}}{{/if}}">{{item.name}}</button></li>
            {{/each}}
          </ul>
        </div>

        <div class="card">
          <div class="list-header">
            <h3>Waffen</h3>
          </div>
          <ul class="item-list interactive-list">
            {{#each itemGroups.weapon as |item|}}
            <li>
              <button type="button" class="item-open" data-action="open-item" data-item-id="{{item._id}}" title="{{#if item.system.rulesShort}}{{item.system.rulesShort}}{{else}}{{item.system.description}}{{/if}}">{{item.name}}</button>
              <span class="item-meta">{{item.system.designedForSizeClass}} → {{item.system.effectiveAgainstClass}} | N {{item.system.rangeBands.nah}} / M {{item.system.rangeBands.mittel}} / W {{item.system.rangeBands.weit}} / E {{item.system.rangeBands.extrem}}</span>
            </li>
            {{/each}}
          </ul>

          <div class="list-header">
            <h3>Rüstung</h3>
          </div>
          <ul class="item-list interactive-list">
            {{#each itemGroups.armor as |item|}}
            <li>
              <button type="button" class="item-open" data-action="open-item" data-item-id="{{item._id}}" title="{{#if item.system.rulesShort}}{{item.system.rulesShort}}{{else}}{{item.system.description}}{{/if}}">{{item.name}}</button>
              <span class="item-meta">{{item.system.userSizeNominal}} | Schutz {{item.system.protectionValue}}</span>
            </li>
            {{/each}}
          </ul>
        </div>
      </div>
    </div>

    <div class="tab" data-group="primary" data-tab="maneuvers">
      <div class="card">
        <h3>Manöver</h3>
        <ul class="item-list">{{#each itemGroups.maneuver as |item|}}<li>{{item.name}}</li>{{/each}}</ul>
      </div>
    </div>

    <div class="tab" data-group="primary" data-tab="advanced">
      <div class="grid two-col">
        <div class="card">
          <h3>{{localize "URoP.Section.Initiative"}}</h3>
          <label>{{localize "URoP.Field.LeadAttribute"}}</label>
          <select name="system.initiative.leadAttribute">
            <option value="koerper" {{#if (uropEq actor.system.initiative.leadAttribute "koerper")}}selected{{/if}}>Körper</option>
            <option value="geist" {{#if (uropEq actor.system.initiative.leadAttribute "geist")}}selected{{/if}}>Geist</option>
            <option value="praesenz" {{#if (uropEq actor.system.initiative.leadAttribute "praesenz")}}selected{{/if}}>Präsenz</option>
          </select>
          <label>{{localize "URoP.Field.BaseMod"}}</label>
          <input type="number" name="system.initiative.baseMod" value="{{actor.system.initiative.baseMod}}"/>
          <label>{{localize "URoP.Field.Target"}}</label>
          <input type="number" name="system.initiative.target" value="{{actor.system.initiative.target}}"/>
          <label>{{localize "URoP.Field.Situational"}}</label>
          <input type="number" name="system.initiative.situational" value="{{actor.system.initiative.situational}}"/>
        </div>

        <div class="card">
          <h3>{{localize "URoP.Section.Temp"}}</h3>
          <p>{{localize "URoP.Help.TempTab"}}</p>

          <label>{{localize "URoP.Field.LockingEnabled"}}</label>
          <input type="checkbox" name="system.meta.locking.enabled" {{#if actor.system.meta.locking.enabled}}checked{{/if}}/>

          <h3>Abgeleitete Werte</h3>
          <label>Körperwert</label>
          <input type="number" value="{{leadAttributeDerived.koerper}}" readonly/>
          <label>Geistwert</label>
          <input type="number" value="{{leadAttributeDerived.geist}}" readonly/>
          <label>Präsenzwert</label>
          <input type="number" value="{{leadAttributeDerived.praesenz}}" readonly/>

          <label>Körperwiderstand</label>
          <input type="number" value="{{resistanceValues.koerper}}" readonly/>
          <label>Geistwiderstand</label>
          <input type="number" value="{{resistanceValues.geist}}" readonly/>
          <label>Präsenzwiderstand</label>
          <input type="number" value="{{resistanceValues.praesenz}}" readonly/>

          <label>Initiative Körper</label>
          <input type="number" value="{{initiativeValues.koerper}}" readonly/>
          <label>Initiative Geist</label>
          <input type="number" value="{{initiativeValues.geist}}" readonly/>
          <label>Initiative Präsenz</label>
          <input type="number" value="{{initiativeValues.praesenz}}" readonly/>
        </div>
      </div>
    </div>
  </section>
</form>
