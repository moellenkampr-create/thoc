<form class="urop-sheet" autocomplete="off">
  <header class="sheet-header">
    <img class="profile-img" src="{{actor.img}}" data-edit="img" title="{{actor.name}}" height="96" width="96"/>
    <div class="header-main">
      <input name="name" type="text" value="{{actor.name}}" placeholder="{{localize 'URoP.Character.Name'}}"/>
      <div class="quick-rolls">
        <button type="button" data-action="roll-urop" data-label="{{localize 'URoP.Roll.Generic'}}">{{localize "URoP.Roll.ButtonUrop"}}</button>
        <button type="button" data-action="roll-initiative">{{localize "URoP.Roll.InitiativeComparison"}}</button>
      </div>
    </div>
  </header>

  <nav class="sheet-tabs tabs" data-group="primary">
    <a class="item" data-tab="overview">{{localize "URoP.Tab.Overview"}}</a>
    <a class="item" data-tab="attributes">{{localize "URoP.Tab.Attributes"}}</a>
    <a class="item" data-tab="skills">{{localize "URoP.Tab.Skills"}}</a>
    <a class="item" data-tab="consequences">{{localize "URoP.Tab.Consequences"}}</a>
    <a class="item" data-tab="items">{{localize "URoP.Tab.Items"}}</a>
    <a class="item" data-tab="maneuvers">{{localize "URoP.Tab.Maneuvers"}}</a>
    <a class="item" data-tab="advanced">{{localize "URoP.Tab.Advanced"}}</a>
  </nav>

  <section class="sheet-body">
    <div class="tab" data-group="primary" data-tab="overview">
      <div class="grid two-col">
        <div class="card">
          <h3>{{localize "URoP.Section.Resources"}}</h3>
          <label>{{localize "URoP.Field.EPTotal"}}</label>
          <input type="number" name="system.resources.epTotal" value="{{actor.system.resources.epTotal}}"/>
          <div class="field-header">
            <label>{{localize "URoP.Field.EPSpent"}}</label>
            <span class="hover-help help-icon" data-help="{{localize 'URoP.Help.EPSpentRecalc'}}">?</span>
          </div>
          <input type="number" name="system.resources.epSpent" value="{{actor.system.resources.epSpent}}"/>
          <button type="button" data-action="recalc-ep" class="secondary-action">{{localize "URoP.Field.RecalculateEP"}}</button>
          <label>{{localize "URoP.Field.Note"}}</label>
          <textarea name="system.pressure.notes">{{actor.system.pressure.notes}}</textarea>
        </div>

        <div class="card">
          <h3>{{localize "URoP.Section.OverviewNotes"}}</h3>
          <label>{{localize "URoP.Field.Appearance"}}</label>
          <textarea name="system.notes.summary">{{actor.system.notes.summary}}</textarea>
          <label>{{localize "URoP.Field.Backstory"}}</label>
          <textarea class="large" name="system.notes.backstory">{{actor.system.notes.backstory}}</textarea>
        </div>
      </div>
    </div>

    <div class="tab" data-group="primary" data-tab="attributes">
      <div class="card focus-card">
        <div class="field-header">
          <label>{{localize "URoP.Field.FocusAttributes"}}</label>
          <span class="hover-help help-icon" data-help="{{localize 'URoP.Help.FocusAttributes'}}">?</span>
        </div>
        <div class="focus-row">
          <label><input type="checkbox" data-action="toggle-focus-attribute" data-attribute="koerper" {{#if isKoerperFocus}}checked{{/if}}/> Körper</label>
          <label><input type="checkbox" data-action="toggle-focus-attribute" data-attribute="geist" {{#if isGeistFocus}}checked{{/if}}/> Geist</label>
          <label><input type="checkbox" data-action="toggle-focus-attribute" data-attribute="praesenz" {{#if isPraesenzFocus}}checked{{/if}}/> Präsenz</label>
          <button type="button" class="lock-btn" data-action="toggle-focus-lock" title="{{localize 'URoP.Field.FocusLock'}}">{{#if isFocusSelectionLocked}}🔒{{else}}🔓{{/if}}</button>
        </div>
      </div>
      <div class="grid three-col">

        {{!-- KÖRPER --}}
        <div class="card attr-card">
          <div class="attr-header">
            <span class="attr-label hover-help" data-help="{{localize 'URoP.Attr.KoerperHelp'}}">Körper</span>
            <div class="attr-stepper">
              <button type="button" class="stepper-btn" data-action="attr-decrement" data-path="system.attributes.koerper.value">−</button>
              <input type="number" class="attr-value" name="system.attributes.koerper.value" value="{{actor.system.attributes.koerper.value}}" data-locked="true" readonly/>
              <button type="button" class="stepper-btn" data-action="attr-increment" data-path="system.attributes.koerper.value">+</button>
            </div>
            <button type="button" class="lock-btn" data-action="toggle-lock" data-target="system.attributes.koerper.value" title="Bearbeiten sperren/entsperren">🔒</button>
          </div>
          <hr class="attr-divider"/>
          <div class="facet-head">
            <span></span>
            <span class="facet-col-head facet-col-delta hover-help" data-help="{{localize 'URoP.Help.FacetDelta'}}">{{localize "URoP.Field.FacetDelta"}}</span>
            <span class="facet-col-head">{{localize "URoP.Field.FacetTotal"}}</span>
            <span></span>
          </div>
          <div class="facet-row">
            <span class="facet-label hover-help" data-help="{{localize 'URoP.Facet.StaerkeHelp'}}">Stärke</span>
            <div class="facet-stepper">
              <button type="button" class="stepper-btn" data-action="facet-decrement" data-path="system.facets.staerke">−</button>
              <input type="number" class="facet-value" name="system.facets.staerke" value="{{actor.system.facets.staerke}}" data-locked="true" readonly/>
              <button type="button" class="stepper-btn" data-action="facet-increment" data-path="system.facets.staerke">+</button>
            </div>
            <span class="facet-total">{{facetTotals.staerke}}</span>
            <button type="button" class="lock-btn" data-action="toggle-lock" data-target="system.facets.staerke" title="Bearbeiten sperren/entsperren">🔒</button>
          </div>
          <div class="facet-row">
            <span class="facet-label hover-help" data-help="{{localize 'URoP.Facet.GrobmotorikHelp'}}">Grobmotorik</span>
            <div class="facet-stepper">
              <button type="button" class="stepper-btn" data-action="facet-decrement" data-path="system.facets.grobmotorik">−</button>
              <input type="number" class="facet-value" name="system.facets.grobmotorik" value="{{actor.system.facets.grobmotorik}}" data-locked="true" readonly/>
              <button type="button" class="stepper-btn" data-action="facet-increment" data-path="system.facets.grobmotorik">+</button>
            </div>
            <span class="facet-total">{{facetTotals.grobmotorik}}</span>
            <button type="button" class="lock-btn" data-action="toggle-lock" data-target="system.facets.grobmotorik" title="Bearbeiten sperren/entsperren">🔒</button>
          </div>
          <div class="facet-row">
            <span class="facet-label hover-help" data-help="{{localize 'URoP.Facet.FeinmotorikHelp'}}">Feinmotorik</span>
            <div class="facet-stepper">
              <button type="button" class="stepper-btn" data-action="facet-decrement" data-path="system.facets.feinmotorik">−</button>
              <input type="number" class="facet-value" name="system.facets.feinmotorik" value="{{actor.system.facets.feinmotorik}}" data-locked="true" readonly/>
              <button type="button" class="stepper-btn" data-action="facet-increment" data-path="system.facets.feinmotorik">+</button>
            </div>
            <span class="facet-total">{{facetTotals.feinmotorik}}</span>
            <button type="button" class="lock-btn" data-action="toggle-lock" data-target="system.facets.feinmotorik" title="Bearbeiten sperren/entsperren">🔒</button>
          </div>
          <div class="facet-row">
            <span class="facet-label hover-help" data-help="{{localize 'URoP.Facet.KonstitutionHelp'}}">Konstitution</span>
            <div class="facet-stepper">
              <button type="button" class="stepper-btn" data-action="facet-decrement" data-path="system.facets.konstitution">−</button>
              <input type="number" class="facet-value" name="system.facets.konstitution" value="{{actor.system.facets.konstitution}}" data-locked="true" readonly/>
              <button type="button" class="stepper-btn" data-action="facet-increment" data-path="system.facets.konstitution">+</button>
            </div>
            <span class="facet-total">{{facetTotals.konstitution}}</span>
            <button type="button" class="lock-btn" data-action="toggle-lock" data-target="system.facets.konstitution" title="Bearbeiten sperren/entsperren">🔒</button>
          </div>
        </div>

        {{!-- GEIST --}}
        <div class="card attr-card">
          <div class="attr-header">
            <span class="attr-label hover-help" data-help="{{localize 'URoP.Attr.GeistHelp'}}">Geist</span>
            <div class="attr-stepper">
              <button type="button" class="stepper-btn" data-action="attr-decrement" data-path="system.attributes.geist.value">−</button>
              <input type="number" class="attr-value" name="system.attributes.geist.value" value="{{actor.system.attributes.geist.value}}" data-locked="true" readonly/>
              <button type="button" class="stepper-btn" data-action="attr-increment" data-path="system.attributes.geist.value">+</button>
            </div>
            <button type="button" class="lock-btn" data-action="toggle-lock" data-target="system.attributes.geist.value" title="Bearbeiten sperren/entsperren">🔒</button>
          </div>
          <hr class="attr-divider"/>
          <div class="facet-head">
            <span></span>
            <span class="facet-col-head facet-col-delta hover-help" data-help="{{localize 'URoP.Help.FacetDelta'}}">{{localize "URoP.Field.FacetDelta"}}</span>
            <span class="facet-col-head">{{localize "URoP.Field.FacetTotal"}}</span>
            <span></span>
          </div>
          <div class="facet-row">
            <span class="facet-label hover-help" data-help="{{localize 'URoP.Facet.AnalyseHelp'}}">Analyse</span>
            <div class="facet-stepper">
              <button type="button" class="stepper-btn" data-action="facet-decrement" data-path="system.facets.analyse">−</button>
              <input type="number" class="facet-value" name="system.facets.analyse" value="{{actor.system.facets.analyse}}" data-locked="true" readonly/>
              <button type="button" class="stepper-btn" data-action="facet-increment" data-path="system.facets.analyse">+</button>
            </div>
            <span class="facet-total">{{facetTotals.analyse}}</span>
            <button type="button" class="lock-btn" data-action="toggle-lock" data-target="system.facets.analyse" title="Bearbeiten sperren/entsperren">🔒</button>
          </div>
          <div class="facet-row">
            <span class="facet-label hover-help" data-help="{{localize 'URoP.Facet.WillenskraftHelp'}}">Willenskraft</span>
            <div class="facet-stepper">
              <button type="button" class="stepper-btn" data-action="facet-decrement" data-path="system.facets.willenskraft">−</button>
              <input type="number" class="facet-value" name="system.facets.willenskraft" value="{{actor.system.facets.willenskraft}}" data-locked="true" readonly/>
              <button type="button" class="stepper-btn" data-action="facet-increment" data-path="system.facets.willenskraft">+</button>
            </div>
            <span class="facet-total">{{facetTotals.willenskraft}}</span>
            <button type="button" class="lock-btn" data-action="toggle-lock" data-target="system.facets.willenskraft" title="Bearbeiten sperren/entsperren">🔒</button>
          </div>
          <div class="facet-row">
            <span class="facet-label hover-help" data-help="{{localize 'URoP.Facet.AufmerksamkeitHelp'}}">Aufmerksamkeit</span>
            <div class="facet-stepper">
              <button type="button" class="stepper-btn" data-action="facet-decrement" data-path="system.facets.aufmerksamkeit">−</button>
              <input type="number" class="facet-value" name="system.facets.aufmerksamkeit" value="{{actor.system.facets.aufmerksamkeit}}" data-locked="true" readonly/>
              <button type="button" class="stepper-btn" data-action="facet-increment" data-path="system.facets.aufmerksamkeit">+</button>
            </div>
            <span class="facet-total">{{facetTotals.aufmerksamkeit}}</span>
            <button type="button" class="lock-btn" data-action="toggle-lock" data-target="system.facets.aufmerksamkeit" title="Bearbeiten sperren/entsperren">🔒</button>
          </div>
          <div class="facet-row">
            <span class="facet-label hover-help" data-help="{{localize 'URoP.Facet.IntuitionHelp'}}">Intuition</span>
            <div class="facet-stepper">
              <button type="button" class="stepper-btn" data-action="facet-decrement" data-path="system.facets.intuition">−</button>
              <input type="number" class="facet-value" name="system.facets.intuition" value="{{actor.system.facets.intuition}}" data-locked="true" readonly/>
              <button type="button" class="stepper-btn" data-action="facet-increment" data-path="system.facets.intuition">+</button>
            </div>
            <span class="facet-total">{{facetTotals.intuition}}</span>
            <button type="button" class="lock-btn" data-action="toggle-lock" data-target="system.facets.intuition" title="Bearbeiten sperren/entsperren">🔒</button>
          </div>
        </div>

        {{!-- PRÄSENZ --}}
        <div class="card attr-card">
          <div class="attr-header">
            <span class="attr-label hover-help" data-help="{{localize 'URoP.Attr.PraesenzHelp'}}">Präsenz</span>
            <div class="attr-stepper">
              <button type="button" class="stepper-btn" data-action="attr-decrement" data-path="system.attributes.praesenz.value">−</button>
              <input type="number" class="attr-value" name="system.attributes.praesenz.value" value="{{actor.system.attributes.praesenz.value}}" data-locked="true" readonly/>
              <button type="button" class="stepper-btn" data-action="attr-increment" data-path="system.attributes.praesenz.value">+</button>
            </div>
            <button type="button" class="lock-btn" data-action="toggle-lock" data-target="system.attributes.praesenz.value" title="Bearbeiten sperren/entsperren">🔒</button>
          </div>
          <hr class="attr-divider"/>
          <div class="facet-head">
            <span></span>
            <span class="facet-col-head facet-col-delta hover-help" data-help="{{localize 'URoP.Help.FacetDelta'}}">{{localize "URoP.Field.FacetDelta"}}</span>
            <span class="facet-col-head">{{localize "URoP.Field.FacetTotal"}}</span>
            <span></span>
          </div>
          <div class="facet-row">
            <span class="facet-label hover-help" data-help="{{localize 'URoP.Facet.AusdruckHelp'}}">Ausdruck</span>
            <div class="facet-stepper">
              <button type="button" class="stepper-btn" data-action="facet-decrement" data-path="system.facets.ausdruck">−</button>
              <input type="number" class="facet-value" name="system.facets.ausdruck" value="{{actor.system.facets.ausdruck}}" data-locked="true" readonly/>
              <button type="button" class="stepper-btn" data-action="facet-increment" data-path="system.facets.ausdruck">+</button>
            </div>
            <span class="facet-total">{{facetTotals.ausdruck}}</span>
            <button type="button" class="lock-btn" data-action="toggle-lock" data-target="system.facets.ausdruck" title="Bearbeiten sperren/entsperren">🔒</button>
          </div>
          <div class="facet-row">
            <span class="facet-label hover-help" data-help="{{localize 'URoP.Facet.EmpathieHelp'}}">Empathie</span>
            <div class="facet-stepper">
              <button type="button" class="stepper-btn" data-action="facet-decrement" data-path="system.facets.empathie">−</button>
              <input type="number" class="facet-value" name="system.facets.empathie" value="{{actor.system.facets.empathie}}" data-locked="true" readonly/>
              <button type="button" class="stepper-btn" data-action="facet-increment" data-path="system.facets.empathie">+</button>
            </div>
            <span class="facet-total">{{facetTotals.empathie}}</span>
            <button type="button" class="lock-btn" data-action="toggle-lock" data-target="system.facets.empathie" title="Bearbeiten sperren/entsperren">🔒</button>
          </div>
          <div class="facet-row">
            <span class="facet-label hover-help" data-help="{{localize 'URoP.Facet.DominanzHelp'}}">Dominanz</span>
            <div class="facet-stepper">
              <button type="button" class="stepper-btn" data-action="facet-decrement" data-path="system.facets.dominanz">−</button>
              <input type="number" class="facet-value" name="system.facets.dominanz" value="{{actor.system.facets.dominanz}}" data-locked="true" readonly/>
              <button type="button" class="stepper-btn" data-action="facet-increment" data-path="system.facets.dominanz">+</button>
            </div>
            <span class="facet-total">{{facetTotals.dominanz}}</span>
            <button type="button" class="lock-btn" data-action="toggle-lock" data-target="system.facets.dominanz" title="Bearbeiten sperren/entsperren">🔒</button>
          </div>
          <div class="facet-row">
            <span class="facet-label hover-help" data-help="{{localize 'URoP.Facet.ResonanzHelp'}}">Resonanz</span>
            <div class="facet-stepper">
              <button type="button" class="stepper-btn" data-action="facet-decrement" data-path="system.facets.resonanz">−</button>
              <input type="number" class="facet-value" name="system.facets.resonanz" value="{{actor.system.facets.resonanz}}" data-locked="true" readonly/>
              <button type="button" class="stepper-btn" data-action="facet-increment" data-path="system.facets.resonanz">+</button>
            </div>
            <span class="facet-total">{{facetTotals.resonanz}}</span>
            <button type="button" class="lock-btn" data-action="toggle-lock" data-target="system.facets.resonanz" title="Bearbeiten sperren/entsperren">🔒</button>
          </div>
        </div>

      </div>
    </div>

    <div class="tab" data-group="primary" data-tab="skills">
      <div class="card">
        <div class="list-header">
          <h3>Fertigkeiten</h3>
        </div>
        <ul class="item-list interactive-list">
          {{#each itemGroups.skill as |item|}}
          <li>
            <button type="button" class="item-open" data-action="open-item" data-item-id="{{item._id}}" title="{{#if item.system.rulesShort}}{{item.system.rulesShort}}{{else}}{{item.system.description}}{{/if}}">{{item.name}}</button>
            <span class="item-meta">{{item.system.ruleAnchors.[0]}} | {{item.system.ruleAnchors.[1]}} | {{item.system.ruleAnchors.[2]}} | Stufe {{item.system.level}}</span>
          </li>
          {{/each}}
        </ul>
      </div>
    </div>

    <div class="tab" data-group="primary" data-tab="consequences">
      <div class="grid three-col">
        <div class="card">
          <h3>Leichte Konsequenzen</h3>
          <input type="text" name="system.consequences.light.0" value="{{actor.system.consequences.light.[0]}}"/>
          <input type="text" name="system.consequences.light.1" value="{{actor.system.consequences.light.[1]}}"/>
          <input type="text" name="system.consequences.light.2" value="{{actor.system.consequences.light.[2]}}"/>
        </div>
        <div class="card">
          <h3>Schwere Konsequenzen</h3>
          <input type="text" name="system.consequences.heavy.0" value="{{actor.system.consequences.heavy.[0]}}"/>
          <input type="text" name="system.consequences.heavy.1" value="{{actor.system.consequences.heavy.[1]}}"/>
        </div>
        <div class="card">
          <h3>Kritische Konsequenz</h3>
          <input type="text" name="system.consequences.critical.0" value="{{actor.system.consequences.critical.[0]}}"/>
        </div>
      </div>
    </div>

    <div class="tab" data-group="primary" data-tab="items">
      <div class="grid two-col">
        <div class="card">
          <div class="list-header">
            <h3>Ausrüstung</h3>
          </div>
          <ul class="item-list interactive-list">
            {{#each itemGroups.gear as |item|}}
            <li><button type="button" class="item-open" data-action="open-item" data-item-id="{{item._id}}" title="{{#if item.system.rulesShort}}{{item.system.rulesShort}}{{else}}{{item.system.description}}{{/if}}">{{item.name}}</button></li>
            {{/each}}
          </ul>

          <div class="list-header">
            <h3>Verbrauchsgegenstände</h3>
          </div>
          <ul class="item-list interactive-list">
            {{#each itemGroups.consumable as |item|}}
            <li><button type="button" class="item-open" data-action="open-item" data-item-id="{{item._id}}" title="{{#if item.system.rulesShort}}{{item.system.rulesShort}}{{else}}{{item.system.description}}{{/if}}">{{item.name}}</button></li>
            {{/each}}
          </ul>
        </div>

        <div class="card">
          <div class="list-header">
            <h3>Waffen</h3>
          </div>
          <ul class="item-list interactive-list">
            {{#each itemGroups.weapon as |item|}}
            <li><button type="button" class="item-open" data-action="open-item" data-item-id="{{item._id}}" title="{{#if item.system.rulesShort}}{{item.system.rulesShort}}{{else}}{{item.system.description}}{{/if}}">{{item.name}}</button></li>
            {{/each}}
          </ul>

          <div class="list-header">
            <h3>Rüstung</h3>
          </div>
          <ul class="item-list interactive-list">
            {{#each itemGroups.armor as |item|}}
            <li><button type="button" class="item-open" data-action="open-item" data-item-id="{{item._id}}" title="{{#if item.system.rulesShort}}{{item.system.rulesShort}}{{else}}{{item.system.description}}{{/if}}">{{item.name}}</button></li>
            {{/each}}
          </ul>
        </div>
      </div>
    </div>

    <div class="tab" data-group="primary" data-tab="maneuvers">
      <div class="card">
        <h3>Manöver</h3>
        <ul class="item-list">{{#each itemGroups.maneuver as |item|}}<li>{{item.name}}</li>{{/each}}</ul>
      </div>
    </div>

    <div class="tab" data-group="primary" data-tab="advanced">
      <div class="grid two-col">
        <div class="card">
          <h3>{{localize "URoP.Section.Initiative"}}</h3>
          <label>{{localize "URoP.Field.Anchor"}}</label>
          <select name="system.initiative.anchor">
            <option value="koerper" {{#if (uropEq actor.system.initiative.anchor "koerper")}}selected{{/if}}>Körper</option>
            <option value="geist" {{#if (uropEq actor.system.initiative.anchor "geist")}}selected{{/if}}>Geist</option>
            <option value="praesenz" {{#if (uropEq actor.system.initiative.anchor "praesenz")}}selected{{/if}}>Präsenz</option>
          </select>
          <label>{{localize "URoP.Field.BaseMod"}}</label>
          <input type="number" name="system.initiative.baseMod" value="{{actor.system.initiative.baseMod}}"/>
          <label>{{localize "URoP.Field.Target"}}</label>
          <input type="number" name="system.initiative.target" value="{{actor.system.initiative.target}}"/>
          <label>{{localize "URoP.Field.Situational"}}</label>
          <input type="number" name="system.initiative.situational" value="{{actor.system.initiative.situational}}"/>
        </div>

        <div class="card">
          <h3>{{localize "URoP.Section.Temp"}}</h3>
          <label>{{localize "URoP.Field.PressureState"}}</label>
          <select name="system.pressure.state">
            <option value="none" {{#if (uropEq actor.system.pressure.state "none")}}selected{{/if}}>Kein Druck</option>
            <option value="reduced" {{#if (uropEq actor.system.pressure.state "reduced")}}selected{{/if}}>Reduzierter Druck</option>
            <option value="pressure" {{#if (uropEq actor.system.pressure.state "pressure")}}selected{{/if}}>Druck</option>
          </select>
          <p>{{localize "URoP.Help.TempTab"}}</p>

